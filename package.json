{
  "name": "glasswater",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "GLASSWATER — a cozy 2.5D ecosystem & aquarium management sim.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:asset": "node tools/generate-openai-asset.mjs",
    "edit:asset": "node tools/edit-asset-with-fal.mjs",
    "clean:bg": "node tools/remove-backgrounds.mjs"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.4.0",
    "@types/three": "^0.185.0",
    "playwright": "^1.61.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.1",
    "dotenv": "^17.4.2",
    "three": "^0.185.0"
  }
}
